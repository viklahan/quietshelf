# Jetson / Ollama configuration — copy to .env.jetson and use with:
#   docker compose -f docker-compose.jetson.yml up

LLM_PROVIDER=ollama
OLLAMA_HOST=http://ollama:11434

# llama3.1:8b works on Jetson Orin NX 8 GB+
# llama3.1:70b gives better results on AGX Orin (16 GB+ VRAM)
MODEL_NAME=llama3.1:8b

#ACCESS_CODE=

ALLOWED_ORIGINS=*
RATE_LIMIT=10
