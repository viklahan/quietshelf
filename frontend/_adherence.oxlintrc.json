{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/display/**",
              "components/manuscript/**",
              "ui_kits/quiet-fight-club/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Source Serif 4|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Source Serif 4, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconAfter|disabled|onClick|ariaLabel|style|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconAfter, disabled, onClick, ariaLabel, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FoundCheckbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|style|className|key|ref|className|style|children)$/]",
        "message": "<FoundCheckbox> doesn't accept that prop. Declared props: checked, onChange, label, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|title|style|className|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color, title, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:feather|pen-line|film|clapperboard|search|clock|sparkles|circle-check|check|copy|rotate-ccw|x|circle-alert|external-link|list-checks|book-open|file-text|arrow-right)$/]",
        "message": "<Icon> name must be one of 'feather' | 'pen-line' | 'film' | 'clapperboard' | 'search' | 'clock' | 'sparkles' | 'circle-check' | 'check' | 'copy' | 'rotate-ccw' | 'x' | 'circle-alert' | 'external-link' | 'list-checks' | 'book-open' | 'file-text' | 'arrow-right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ManuscriptCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|startTime|endTime|excerpt|mood|moodTone|clipDurationSeconds|terms|found|onFoundChange|style|className|key|ref|className|style|children)$/]",
        "message": "<ManuscriptCard> doesn't accept that prop. Declared props: index, startTime, endTime, excerpt, mood, moodTone, clipDurationSeconds, terms, found, onFoundChange, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ManuscriptCard'] > JSXAttribute[name.name='moodTone'] > Literal[value!=/^(?:neutral|ember|oxblood|paper)$/]",
        "message": "<ManuscriptCard> moodTone must be one of 'neutral' | 'ember' | 'oxblood' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|style|className|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, label, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScriptTextarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|minHeight|ariaLabel|style|className|key|ref|className|style|children)$/]",
        "message": "<ScriptTextarea> doesn't accept that prop. Declared props: value, onChange, placeholder, minHeight, ariaLabel, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:term|best|href|onClick|style|className|key|ref|className|style|children)$/]",
        "message": "<SearchChip> doesn't accept that prop. Declared props: term, best, href, onClick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|className|key|ref|className|style|children)$/]",
        "message": "<Stamp> doesn't accept that prop. Declared props: children, tone, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|ember|oxblood|paper)$/]",
        "message": "<Stamp> tone must be one of 'neutral' | 'ember' | 'oxblood' | 'paper'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
