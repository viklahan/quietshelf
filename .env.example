# Which AI provider to use: gemini (default), groq, or ollama.
# All three are free - there is no paid provider in this codebase.
LLM_PROVIDER=gemini

# Required when LLM_PROVIDER=gemini.
# Free key (no card needed) at https://aistudio.google.com
GEMINI_API_KEY=

# Required when LLM_PROVIDER=groq.
# Free key (no card needed) at https://console.groq.com
#GROQ_API_KEY=

# Used when LLM_PROVIDER=ollama. No key needed at all.
# Install Ollama free at https://ollama.com, then: ollama pull llama3.1:8b
# Running the app in Docker with Ollama on the host? Use:
#   OLLAMA_HOST=http://host.docker.internal:11434
#OLLAMA_HOST=http://localhost:11434

# Optional. Model override; sensible default per provider:
#   gemini: gemini-2.5-flash | groq: llama-3.3-70b-versatile | ollama: llama3.1:8b
#MODEL_NAME=

# Optional. If set, requests to /api/map must send a matching X-Access-Code
# header (this is how a hosted instance stays semi-private). Leave unset to
# keep the API open - fine for self-hosters.
#ACCESS_CODE=

# Optional. Comma-separated CORS origins. Default: * (open, fine for v0).
ALLOWED_ORIGINS=*

# Optional. Requests per hour per IP for /api/map. Protects your free-tier
# quota from randoms.
RATE_LIMIT=10

# Optional. Port to serve on (Render/Railway set this automatically).
#PORT=8000
