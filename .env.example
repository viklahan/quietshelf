# Which free AI backend to use: gemini | groq | ollama
# All three are free - there is no paid provider in this codebase.
# (The Format service uses no AI at all.)
LLM_PROVIDER=gemini

# Required when LLM_PROVIDER=gemini. Free key, no card:
#   https://aistudio.google.com
GEMINI_API_KEY=

# Required when LLM_PROVIDER=groq. Free key, no card:
#   https://console.groq.com
GROQ_API_KEY=

# Used when LLM_PROVIDER=ollama. No key needed - fully local/offline.
# Install free at https://ollama.com, then: ollama pull qwen2.5:latest
# Running the app in Docker with Ollama on the host? Use:
#   OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434

# Optional model override (otherwise a sensible default per provider):
#   gemini: gemini-2.5-flash | groq: llama-3.3-70b-versatile | ollama: qwen2.5:latest
MODEL_NAME=

# Optional shared access code; if set, requests need a matching X-Access-Code
# header. Leave unset to keep the API open (fine for self-hosters).
ACCESS_CODE=

# Optional. Comma-separated CORS origins. Default: * (open).
ALLOWED_ORIGINS=*

# Optional. Requests per hour per IP - protects your free-tier quota.
# Read as an integer; the "/hour" suffix is documentation only.
RATE_LIMIT=20/hour

# Optional. Max upload size in MB for manuscript files.
MAX_UPLOAD_MB=25
